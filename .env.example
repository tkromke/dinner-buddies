# Copy this file to .env and fill in real values. Never commit .env.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API key (for the agent's reasoning)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Maps API key (Places + Distance Matrix)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Telegram user IDs — get yours by messaging @userinfobot
TOBIAS_TELEGRAM_USER_ID=123456789
CHLOE_TELEGRAM_USER_ID=987654321
